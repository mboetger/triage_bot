{
  "firestore": {
    "rules": "firestore.rules"
  },
  "functions": {
    "source": "functions",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "*.local"
    ],
    "predeploy": "npm --prefix functions run build"    
  },
  "hosting": {
    "public": "build/jaspr",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/statistics",
        "function": "getBranchStatistics"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
